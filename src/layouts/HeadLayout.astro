---
// src/components/layout/Head.astro
import { ViewTransitions } from "astro:transitions";
import SEO from "@/components/seo/SEO.astro";
import seo from "@/data/seo.json";

export interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  type?: string;
}

const { pathname } = Astro.url;
const currentLang = Astro.currentLocale || "es";

function normalizePath(path: string): string {
  if (path === "/" || path === "/en/") return path;
  return path.endsWith("/") ? path.slice(0, -1) : path;
}

function matchSEO(
  pages: Array<{ path: string; title: string; description: string }>,
  path: string,
): { path: string; title: string; description: string } | undefined {
  if (!Array.isArray(pages)) return undefined;
  const normalizedPath = normalizePath(path);
  let found = pages.find((p) => normalizePath(p.path) === normalizedPath);
  if (found) return found;
  found = pages.find(
    (p) =>
      p.path.endsWith("/*") &&
      normalizedPath.startsWith(normalizePath(p.path.replace("/*", ""))),
  );
  return found;
}

const matchedSEO = matchSEO(seo.pages, pathname);
const props = Astro.props || {};
function isValid(val: unknown): val is string {
  return typeof val === "string" && val.trim().length > 0;
}

const defaultSEO =
  currentLang === "en"
    ? {
        title: seo.en?.title || seo.default.title,
        description: seo.en?.description || seo.default.description,
      }
    : {
        title: seo.default.title,
        description: seo.default.description,
      };
const defaultType = pathname.includes("/projects/")
  ? "article"
  : pathname.includes("/about")
    ? "profile"
    : seo.default.type;

const pageSEO = {
  title: isValid(props.title)
    ? props.title
    : matchedSEO && isValid(matchedSEO.title)
      ? matchedSEO.title
      : defaultSEO.title,
  description: isValid(props.description)
    ? props.description
    : matchedSEO && isValid(matchedSEO.description)
      ? matchedSEO.description
      : defaultSEO.description,
};
---

<head>
  <ViewTransitions />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Google Tag Manager -->
  <script>
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != "dataLayer" ? "&l=" + l : "";
      j.async = true;
      j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, "script", "dataLayer", "GTM-KLZKSS6B");
  </script>
  <!-- End Google Tag Manager -->
  <script is:inline src="https://t.contentsquare.net/uxa/d5eecf66467a1.js"
  ></script>
  <link
    rel="preload"
    href="/fonts/Kufam-VariableFont_wght.ttf"
    as="font"
    type="font/ttf"
    crossorigin
  />
  <SEO
    title={pageSEO.title}
    description={pageSEO.description}
    keywords={currentLang === "en" ? seo.en?.keywords : seo.default.keywords}
    author={seo.default.author}
    image={props.image || seo.default.image}
    siteName={seo.default.siteName}
    locale={currentLang === "en" ? "en_US" : "es_ES"}
    type={props.type || defaultType}
    robots="index, follow"
  />

  <!-- PREVENT FLASH + MANEJO REAL DEL THEME -->
  <script>
    (function () {
      const saved = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;

      let theme = "light";
      if (saved === "dark") {
        theme = "dark";
      } else if (saved === "light") {
        theme = "light";
      } else {
        // system or undefined
        theme = prefersDark ? "dark" : "light";
      }

      document.documentElement.setAttribute("data-theme", theme);
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    })();
  </script>
</head>
