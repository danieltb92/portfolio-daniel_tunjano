---
import "@/styles/global.css";
import "@/styles/animations.css";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import { useTranslations } from "@/i18n/utils";
import { languageList } from "@/i18n/ui";
import Head from "@/layouts/HeadLayout.astro";
import CursorTrail from "@/components/effects/CursorTrail.astro";

const currentLang = Astro.currentLocale || "es";
const translateLabels = useTranslations(
  currentLang as keyof typeof languageList,
);
---

<!doctype html>
<html lang={currentLang}>
  <Head title={Astro.props.title} description={Astro.props.description} />
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KLZKSS6B"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <main>
      <Header />
      <slot />
      <Footer />
    </main>
    <CursorTrail />
  </body>
</html>

<script>
  import { initAllAnimations, cleanupAnimations } from "@/lib/animations";

  // Redirect to English if browser language is English and user is on default (Spanish) root
  if (location.pathname === "/") {
    const alreadyRedirected = sessionStorage.getItem("lang-redirected");
    if (!alreadyRedirected) {
      const browserLang = navigator.language || (navigator as any).userLanguage;
      if (browserLang?.startsWith("en")) {
        sessionStorage.setItem("lang-redirected", "true");
        location.href = "/en/";
      }
    }
  }

  // Ejecutar al cargar la página inicial
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllAnimations);
  } else {
    initAllAnimations();
  }

  // Soporte para transiciones de vista de Astro (ViewTransitions / ClientRouter)
  document.addEventListener("astro:before-swap", cleanupAnimations);
  document.addEventListener("astro:after-swap", initAllAnimations);
</script>
