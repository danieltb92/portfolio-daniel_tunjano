<!-- Glow Effect -->
<div
  id="cursor-glow"
  class="pointer-events-none fixed inset-0 z-[9000] overflow-hidden hidden md:block"
>
  <div class="glow-point"></div>
</div>

<style>
  .glow-point {
    position: absolute;
    top: 0;
    left: 0;
    width: 400px; /* Large visible area */
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(29, 78, 216, 0.15) 0%,
      rgba(29, 78, 216, 0) 70%
    ); /* Blueish glow */
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    mix-blend-mode: screen; /* Nice blending */
    will-change: transform;
    opacity: 0; /* Start hidden */
  }

  :global(.dark) .glow-point {
    background: radial-gradient(
      circle,
      rgba(100, 149, 237, 0.1) 0%,
      rgba(0, 0, 0, 0) 70%
    );
  }
</style>

<script>
  const initCursorGlow = () => {
    const glow = document.querySelector(".glow-point") as HTMLElement;
    if (!glow) return;

    glow.style.transform = "translate(-50%, -50%)";
    glow.style.opacity = "0";

    let currentX = window.innerWidth / 2;
    let currentY = window.innerHeight / 2;
    let targetX = currentX;
    let targetY = currentY;
    let isMoving = false;

    const lerp = (start: number, end: number, factor: number) => {
      return start + (end - start) * factor;
    };

    const animate = () => {
      currentX = lerp(currentX, targetX, 0.05);
      currentY = lerp(currentY, targetY, 0.05);
      glow.style.transform = `translate(calc(-50% + ${currentX}px), calc(-50% + ${currentY}px))`;
      
      if (Math.abs(targetX - currentX) > 0.1 || Math.abs(targetY - currentY) > 0.1) {
        requestAnimationFrame(animate);
      } else {
        isMoving = false;
      }
    };

    const moveGlow = (e: MouseEvent) => {
      if (glow.style.opacity === "0") {
        glow.style.transition = "opacity 0.5s ease";
        glow.style.opacity = "1";
      }

      targetX = e.clientX;
      targetY = e.clientY;

      if (!isMoving) {
        isMoving = true;
        requestAnimationFrame(animate);
      }
    };

    window.addEventListener("mousemove", moveGlow);

    document.body.addEventListener("mouseleave", () => {
      glow.style.opacity = "0";
    });
    document.body.addEventListener("mouseenter", () => {
      glow.style.opacity = "1";
    });
  };

  initCursorGlow();
  document.addEventListener("astro:after-swap", initCursorGlow);
</script>
